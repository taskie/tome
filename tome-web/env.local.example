# URL of the running tome-server (default: http://localhost:8080)
TOME_API_URL=http://localhost:8080

# Set to "aws-iam" to enable AWS SigV4 signing for Lambda Function URL
# TOME_AUTH=aws-iam

# AWS region for SigV4 signing (default: AWS_REGION env var or us-east-1)
# TOME_AWS_REGION=us-west-2

# AWS service name for SigV4 signing (default: lambda)
# TOME_AWS_SERVICE=lambda
