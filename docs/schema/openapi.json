{
  "openapi": "3.0.3",
  "info": {
    "title": "tome API",
    "description": "HTTP API for the tome file change tracking system.",
    "license": {
      "name": ""
    },
    "version": "0.1.0"
  },
  "paths": {
    "/diff": {
      "get": {
        "tags": [
          "repositories"
        ],
        "operationId": "diff_repos",
        "parameters": [
          {
            "name": "repo1",
            "in": "query",
            "description": "First repository name.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "prefix1",
            "in": "query",
            "description": "Optional path prefix for repo1.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "repo2",
            "in": "query",
            "description": "Second repository name.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "prefix2",
            "in": "query",
            "description": "Optional path prefix for repo2.",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Cross-repository diff from entry_cache",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RepoDiffResponse"
                }
              }
            }
          },
          "400": {
            "description": "Too many entries",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/machines": {
      "get": {
        "tags": [
          "machines"
        ],
        "operationId": "list_machines",
        "responses": {
          "200": {
            "description": "List registered machines",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MachineResponse"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "machines"
        ],
        "operationId": "register_machine",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterMachineRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Registered machine",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MachineResponse"
                }
              }
            }
          }
        }
      }
    },
    "/machines/{id}": {
      "put": {
        "tags": [
          "machines"
        ],
        "operationId": "update_machine",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Machine ID",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Updated machine (last_seen_at refreshed)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MachineResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/objects/{digest}": {
      "get": {
        "tags": [
          "objects"
        ],
        "operationId": "get_object",
        "parameters": [
          {
            "name": "digest",
            "in": "path",
            "description": "Object SHA-256/BLAKE3 digest (hex)",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Object metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ObjectResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid digest",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/objects/{digest}/entries": {
      "get": {
        "tags": [
          "objects"
        ],
        "operationId": "list_object_entries",
        "parameters": [
          {
            "name": "digest",
            "in": "path",
            "description": "Object digest (hex)",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "All snapshot+entry pairs referencing this object",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SnapshotEntry"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid digest",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/repositories": {
      "get": {
        "tags": [
          "repositories"
        ],
        "operationId": "list_repositories",
        "responses": {
          "200": {
            "description": "List all repositories",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/RepositoryResponse"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/repositories/{name}": {
      "get": {
        "tags": [
          "repositories"
        ],
        "operationId": "get_repository",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "description": "Repository name",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Repository details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RepositoryResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/repositories/{name}/diff": {
      "get": {
        "tags": [
          "repositories"
        ],
        "operationId": "diff_snapshots",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "description": "Repository name",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "snapshot1",
            "in": "query",
            "description": "First snapshot ID (decimal).",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "snapshot2",
            "in": "query",
            "description": "Second snapshot ID (decimal).",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "prefix",
            "in": "query",
            "description": "Optional path prefix filter.",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Diff between two snapshots",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DiffResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/repositories/{name}/files": {
      "get": {
        "tags": [
          "repositories"
        ],
        "operationId": "list_files",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "description": "Repository name",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "prefix",
            "in": "query",
            "description": "Optional path prefix filter (mutually exclusive with `dir`).",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "dir",
            "in": "query",
            "description": "Optional directory path for directory listing (mutually exclusive with `prefix`).",
            "required": false,
            "schema": {
              "type": "string",
              "nullable": true
            }
          },
          {
            "name": "include_deleted",
            "in": "query",
            "description": "Include deleted entries (status=0).",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number (1-based, default 1).",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64",
              "minimum": 0
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "Items per page (1–500, default 100).",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64",
              "minimum": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of tracked files from entry_cache",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FilesResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/repositories/{name}/history": {
      "get": {
        "tags": [
          "repositories"
        ],
        "operationId": "path_history",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "description": "Repository name",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "path",
            "in": "query",
            "description": "File path to retrieve history for.",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Snapshot+entry pairs for the given path",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SnapshotEntry"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/repositories/{name}/latest": {
      "get": {
        "tags": [
          "repositories"
        ],
        "operationId": "get_latest_snapshot",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "description": "Repository name",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Latest snapshot, or null if none",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/SnapshotResponse"
                    }
                  ],
                  "nullable": true
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/repositories/{name}/snapshots": {
      "get": {
        "tags": [
          "repositories"
        ],
        "operationId": "list_snapshots",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "description": "Repository name",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List snapshots for the repository",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SnapshotResponse"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/snapshots/{id}/entries": {
      "get": {
        "tags": [
          "snapshots"
        ],
        "operationId": "list_entries",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Snapshot ID (decimal)",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "prefix",
            "in": "query",
            "description": "Optional path prefix filter.",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Entries in the snapshot",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/EntryResponse"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid snapshot id",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/stores": {
      "get": {
        "tags": [
          "admin"
        ],
        "operationId": "list_stores",
        "responses": {
          "200": {
            "description": "List all stores",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/StoreResponse"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/sync-peers": {
      "get": {
        "tags": [
          "admin"
        ],
        "operationId": "list_all_sync_peers",
        "responses": {
          "200": {
            "description": "List all sync peers",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SyncPeerResponse"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/sync/pull": {
      "get": {
        "tags": [
          "sync"
        ],
        "operationId": "pull",
        "parameters": [
          {
            "name": "repo",
            "in": "query",
            "description": "Repository name.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "after",
            "in": "query",
            "description": "Decimal snapshot ID; return only snapshots created after this one.",
            "required": false,
            "schema": {
              "type": "string",
              "nullable": true
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Incremental snapshots since `after`",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PullResponse"
                }
              }
            }
          },
          "404": {
            "description": "Repository not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/sync/push": {
      "post": {
        "tags": [
          "sync"
        ],
        "operationId": "push",
        "parameters": [
          {
            "name": "repo",
            "in": "query",
            "description": "Repository name.",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PushRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Snapshot created (or existing returned for idempotent re-push)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PushResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/tags": {
      "get": {
        "tags": [
          "admin"
        ],
        "operationId": "list_all_tags",
        "responses": {
          "200": {
            "description": "List all blob tags",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TagResponse"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CacheEntryResponse": {
        "type": "object",
        "required": [
          "path",
          "status",
          "snapshot_id",
          "entry_id",
          "is_directory"
        ],
        "properties": {
          "digest": {
            "type": "string",
            "nullable": true
          },
          "entry_id": {
            "type": "string"
          },
          "fast_digest": {
            "type": "string",
            "nullable": true
          },
          "is_directory": {
            "type": "boolean"
          },
          "mtime": {
            "type": "string",
            "nullable": true
          },
          "path": {
            "type": "string"
          },
          "size": {
            "type": "integer",
            "format": "int64",
            "nullable": true
          },
          "snapshot_id": {
            "type": "string"
          },
          "status": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "DiffResponse": {
        "type": "object",
        "required": [
          "snapshot1",
          "snapshot2",
          "objects",
          "entries",
          "diff"
        ],
        "properties": {
          "diff": {
            "type": "object",
            "description": "object_id → [entry_ids_in_snapshot1, entry_ids_in_snapshot2]",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "entries": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/components/schemas/EntryResponse"
            }
          },
          "objects": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/components/schemas/ObjectResponse"
            }
          },
          "snapshot1": {
            "$ref": "#/components/schemas/SnapshotResponse"
          },
          "snapshot2": {
            "$ref": "#/components/schemas/SnapshotResponse"
          }
        }
      },
      "EntryResponse": {
        "type": "object",
        "required": [
          "id",
          "snapshot_id",
          "path",
          "status",
          "created_at"
        ],
        "properties": {
          "created_at": {
            "type": "string"
          },
          "digest": {
            "type": "string",
            "nullable": true
          },
          "id": {
            "type": "string"
          },
          "mode": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "mtime": {
            "type": "string",
            "nullable": true
          },
          "object_id": {
            "type": "string",
            "nullable": true
          },
          "path": {
            "type": "string"
          },
          "snapshot_id": {
            "type": "string"
          },
          "status": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "description": "Error response body returned for 4xx/5xx responses.",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "type": "string"
          }
        }
      },
      "FilesResponse": {
        "type": "object",
        "required": [
          "total",
          "page",
          "per_page",
          "items"
        ],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CacheEntryResponse"
            }
          },
          "page": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "per_page": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "total": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          }
        }
      },
      "MachineResponse": {
        "type": "object",
        "required": [
          "machine_id",
          "name",
          "description",
          "created_at"
        ],
        "properties": {
          "created_at": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "last_seen_at": {
            "type": "string",
            "nullable": true
          },
          "machine_id": {
            "type": "integer",
            "format": "int32"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "ObjectResponse": {
        "type": "object",
        "required": [
          "id",
          "digest",
          "size",
          "fast_digest",
          "created_at"
        ],
        "properties": {
          "created_at": {
            "type": "string"
          },
          "digest": {
            "type": "string"
          },
          "fast_digest": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "size": {
            "type": "integer",
